          content: `<?xml version="1.0" encoding="UTF-8" standalone="yes"?><Relationships xmlns="http://schemas.openxmlformats.org/package/2006/relationships"><Relationship Id="rId1" Type="http://schemas.openxmlformats.org/officeDocument/2006/relationships/slideMaster" Target="../slideMasters/slideMaster1.xml"/></Relationships>`,
        },
        {
          name: "ppt/theme/theme1.xml",
          content: `<?xml version="1.0" encoding="UTF-8" standalone="yes"?><a:theme xmlns:a="http://schemas.openxmlformats.org/drawingml/2006/main" name="Church Slides"><a:themeElements><a:clrScheme name="Dark"><a:dk1><a:srgbClr val="090A0D"/></a:dk1><a:lt1><a:srgbClr val="FFFDF9"/></a:lt1><a:dk2><a:srgbClr val="1F1F1F"/></a:dk2><a:lt2><a:srgbClr val="EEE8DC"/></a:lt2><a:accent1><a:srgbClr val="B21F2D"/></a:accent1><a:accent2><a:srgbClr val="93D3A6"/></a:accent2><a:accent3><a:srgbClr val="D7C9B7"/></a:accent3><a:accent4><a:srgbClr val="FFFFFF"/></a:accent4><a:accent5><a:srgbClr val="666666"/></a:accent5><a:accent6><a:srgbClr val="111111"/></a:accent6><a:hlink><a:srgbClr val="B21F2D"/></a:hlink><a:folHlink><a:srgbClr val="B21F2D"/></a:folHlink></a:clrScheme><a:fontScheme name="Arial"><a:majorFont><a:latin typeface="Arial"/></a:majorFont><a:minorFont><a:latin typeface="Arial"/></a:minorFont></a:fontScheme><a:fmtScheme name="Simple"><a:fillStyleLst><a:solidFill><a:schemeClr val="phClr"/></a:solidFill></a:fillStyleLst><a:lnStyleLst><a:ln w="6350"><a:solidFill><a:schemeClr val="phClr"/></a:solidFill></a:ln></a:lnStyleLst><a:effectStyleLst><a:effectStyle><a:effectLst/></a:effectStyle></a:effectStyleLst><a:bgFillStyleLst><a:solidFill><a:schemeClr val="phClr"/></a:solidFill></a:bgFillStyleLst></a:fmtScheme></a:themeElements></a:theme>`,
        },
        ...slides.map((slide, index) => ({
          name: `ppt/slides/slide${index + 1}.xml`,
          content: createSlideXml(slide),
        })),
        ...slides.map((_, index) => ({
          name: `ppt/slides/_rels/slide${index + 1}.xml.rels`,
          content: `<?xml version="1.0" encoding="UTF-8" standalone="yes"?><Relationships xmlns="http://schemas.openxmlformats.org/package/2006/relationships"><Relationship Id="rId1" Type="http://schemas.openxmlformats.org/officeDocument/2006/relationships/slideLayout" Target="../slideLayouts/slideLayout1.xml"/></Relationships>`,
        })),
      ];

      return createZipBlob(files);
    };

    const downloadPowerPoint = async (
      slides: PowerPointSlide[],
      title: string,
      filename: string,
    ) => {
      const pptx = new pptxgen();

      pptx.layout = "LAYOUT_WIDE";
      pptx.author = "wesley.org.ua";
      pptx.company = "wesley.org.ua";
      pptx.subject = "Church slides";
      pptx.title = title;
      pptx.lang = "uk-UA";
      pptx.theme = {
        headFontFace: "Arial",
        bodyFontFace: "Arial",
        lang: "uk-UA",
      };

      slides.forEach((slideContent) => {
        const slide = pptx.addSlide();
        const hasTitle = Boolean(slideContent.title);

        slide.background = { color: "090A0D" };

        if (slideContent.title) {
          slide.addText(slideContent.title, {
            x: 0.35,
            y: 0.25,
            w: 12.63,
            h: 1.05,
            margin: 0,
            fontFace: "Arial",
            fontSize: 32,
            bold: true,
            color: "FFFDF9",
            align: "center",
            valign: "mid",
          });
        }

        slide.addText(slideContent.text, {
          x: 0.45,
          y: hasTitle ? 1.35 : 0.35,
          w: 12.43,
          h: hasTitle ? 5.75 : 6.8,
          margin: 0,
          fontFace: "Arial",
          fontSize: 54,
          bold: true,
          color: "FFFDF9",
          align: "center",
          valign: "mid",
          fit: "shrink",
        });
      });

      await pptx.writeFile({ fileName: filename });
    };

    const downloadBlob = (blob: Blob, filename: string) => {
      const url = URL.createObjectURL(blob);
      const link = document.createElement("a");
      link.href = url;
      link.download = filename;
      document.body.append(link);
      link.click();
      link.remove();
      URL.revokeObjectURL(url);
    };

    const slugifyFilename = (value: string) =>
      value
        .toLowerCase()
        .replace(/[^\p{L}\p{N}]+/gu, "-")
        .replace(/^-+|-+$/g, "")
        .slice(0, 80) || "slides";

    document
      .querySelectorAll<HTMLButtonElement>(".song-copy-button")
      .forEach((button) => {
        let resetTimer: number | undefined;

        button.addEventListener("click", async () => {
          const buttonLabel = button.querySelector("span");
          const songBlock = button.closest(".song-slides");
          const source =
            songBlock?.querySelector<HTMLTextAreaElement>(".song-copy-source");
          const slideText = source?.value.trim();

          if (!slideText) return;

          await writeToClipboard(slideText);

          window.clearTimeout(resetTimer);
          if (buttonLabel) buttonLabel.textContent = copiedLabel;
          button.classList.add("is-copied");

          resetTimer = window.setTimeout(() => {
            if (buttonLabel) buttonLabel.textContent = defaultLabel;
            button.classList.remove("is-copied");
          }, 1400);
        });
      });

    document
      .querySelectorAll<HTMLButtonElement>(".song-pptx-button")
      .forEach((button) => {
        let resetTimer: number | undefined;

        button.addEventListener("click", async () => {
          const buttonLabel = button.querySelector("span");
          const songBlock = button.closest(".song-slides");
          const title =
            songBlock?.querySelector("h2")?.textContent?.trim() ?? "slides";
          const slides = getSongSlides(songBlock).map((slide, index) => ({
            text: slide,
            title: index === 0 ? title : "",
          }));

          if (!slides.length) return;

          await downloadPowerPoint(slides, title, `${slugifyFilename(title)}.pptx`);

          window.clearTimeout(resetTimer);
          if (buttonLabel) buttonLabel.textContent = "Завантажено";
          button.classList.add("is-copied");

          resetTimer = window.setTimeout(() => {
            if (buttonLabel) buttonLabel.textContent = "PowerPoint";
            button.classList.remove("is-copied");
          }, 1400);
        });
      });

    document
      .querySelectorAll<HTMLButtonElement>(".song-preview-button")
      .forEach((button) => {
        button.addEventListener("click", () => {
          const songBlock = button.closest(".song-slides");
          const title =
            songBlock?.querySelector("h2")?.textContent?.trim() ?? "";
          const slides = getSongSlides(songBlock);

          openSlides(createPreviewSlides(slides, title));
        });
      });

    previewPrevious?.addEventListener("click", () => showPreviewSlide(-1));
    previewNext?.addEventListener("click", () => showPreviewSlide(1));
    previewDownload?.addEventListener("click", async () => {
      if (!activePowerPointSlides.length) return;

      await downloadPowerPoint(
        activePowerPointSlides,
        activeDownloadTitle,
        activeDownloadFilename,
      );
    });
    previewClose?.addEventListener("click", () => {
      closePreview();
    });

    previewDialog?.addEventListener("click", (event) => {
      if (event.target === previewDialog) closePreview();
    });

    previewDialog?.addEventListener("close", () => {
      if (previewRequestedFullscreen && document.fullscreenElement) {
        document.exitFullscreen();
      }

      previewRequestedFullscreen = false;
    });

    previewStage?.addEventListener("pointerdown", (event) => {
      if (!previewDialog?.open) return;

      swipeStartX = event.clientX;
      swipeStartY = event.clientY;
      swipeStartTime = Date.now();
    });

    previewStage?.addEventListener("pointerup", (event) => {
      if (!previewDialog?.open || !swipeStartTime) return;

      const deltaX = event.clientX - swipeStartX;
      const deltaY = event.clientY - swipeStartY;
      const elapsed = Date.now() - swipeStartTime;
      const isHorizontalSwipe =
        Math.abs(deltaX) > 60 && Math.abs(deltaX) > Math.abs(deltaY) * 1.35;

      swipeStartTime = 0;

      if (!isHorizontalSwipe || elapsed > 900) return;

      showPreviewSlide(deltaX < 0 ? 1 : -1);
    });

    previewStage?.addEventListener("pointercancel", () => {
      swipeStartTime = 0;
    });

    document.addEventListener("keydown", (event) => {
      if (!previewDialog?.open) return;

      if (event.key === "ArrowLeft") {
        event.preventDefault();
        showPreviewSlide(-1);
      }

      if (event.key === "ArrowRight") {
        event.preventDefault();
        showPreviewSlide(1);
      }
    });

    window.addEventListener("hashchange", openGroupFromUrl);
    openGroupFromUrl();
  </script>
</BaseLayout>
