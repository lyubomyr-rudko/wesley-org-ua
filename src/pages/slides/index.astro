---
import BaseLayout from "../../layouts/BaseLayout.astro";
import slidesManifest from "../../../slides/manifest.json";

const baseUrl = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const withBase = (path) => `${baseUrl}${path.replace(/^\/+/, "")}`;

type SlideManifestEntry = {
  id: string;
  filename: string;
  title: string;
  displayTitle: string;
};

const slideFiles = import.meta.glob("../../../slides/*.md", {
  eager: true,
  query: "?raw",
  import: "default",
});

const slides = (slidesManifest as SlideManifestEntry[]).map((song) => {
  const raw = slideFiles[`../../../slides/${song.filename}`] as string;
  const lines = raw.trim().split(/\r?\n/);
  const body = lines.slice(1).join("\n").trim();

  return {
    ...song,
    rawContent: raw.trim(),
    anchorId: song.filename.replace(/\.md$/, ""),
    slides: body
      .split(/\n\s*---\s*\n/g)
      .map((slide) => slide.trim())
      .filter(Boolean),
  };
});
---

<BaseLayout
  title="Церковний Пісенник"
  description="Церковний Пісенник з текстами пісень."
>
  <div class="resource-shell slides-shell">
    <section class="resource-hero">
      <p class="resource-kicker">Церковний Пісенник</p>
      <h1 class="resource-title">Церковний Пісенник</h1>
      <div class="home-actions">
        <a class="button-primary" href={withBase("/slides/builder/")}>
          Збудувати
        </a>
      </div>
    </section>

    <section class="resource-panel">
      <div class="resource-panel-header">
        <p class="archive-eyebrow">Пісні</p>
        <h2>Перелік слайдів</h2>
        <p class="archive-summary">
          У списку зараз: <span class="count">{slides.length}</span> пісень
        </p>
      </div>

      <ol class="slides-index">
        {
          slides.map((song) => (
            <li>
              <a href={`#${song.anchorId}`}>{song.displayTitle}</a>
            </li>
          ))
        }
      </ol>
    </section>

    <section class="slides-list" aria-label="Церковний Пісенник">
      {
        slides.map((song) => (
          <article
            class="song-slides"
            id={song.anchorId}
            data-song-id={song.id}
            data-song-number={Number(song.id)}
          >
            <header class="song-slides-header">
              <p class="sermon-year">{song.filename}</p>
              <h2>{song.displayTitle}</h2>
              <div class="song-slide-actions">
                <button
                  class="slide-action-button song-copy-button"
                  type="button"
                >
                  <svg
                    class="slide-action-icon"
                    aria-hidden="true"
                    viewBox="0 0 24 24"
                  >
                    <rect x="8" y="8" width="11" height="11" rx="2"></rect>
                    <path d="M5 15H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v1"></path>
                  </svg>
                  <span>Копіювати текст</span>
                </button>
                <button
                  class="slide-action-button song-preview-button"
                  type="button"
                >
                  <svg
                    class="slide-action-icon"
                    aria-hidden="true"
                    viewBox="0 0 24 24"
                  >
                    <path d="M8 3H5a2 2 0 0 0-2 2v3"></path>
                    <path d="M16 3h3a2 2 0 0 1 2 2v3"></path>
                    <path d="M8 21H5a2 2 0 0 1-2-2v-3"></path>
                    <path d="M16 21h3a2 2 0 0 0 2-2v-3"></path>
                  </svg>
                  <span>Переглянути слайди</span>
                </button>
                <button
                  class="slide-action-button song-pptx-button"
                  type="button"
                >
                  <svg
                    class="slide-action-icon"
                    aria-hidden="true"
                    viewBox="0 0 24 24"
                  >
                    <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
                    <path d="M14 2v6h6"></path>
                    <path d="M12 18v-6"></path>
                    <path d="m9 15 3 3 3-3"></path>
                  </svg>
                  <span>PowerPoint</span>
                </button>
              </div>
              <textarea class="song-copy-source" readonly>
                {song.rawContent}
              </textarea>
            </header>

            <div class="slide-grid">
              {song.slides.map((slide, index) => (
                <section class="slide-card">
                  <p class="slide-number">Слайд {index + 1}</p>
                  {index === 0 && (
                    <h3 class="slide-card-title">{song.displayTitle}</h3>
                  )}
                  <pre>{slide}</pre>
                </section>
              ))}
            </div>
          </article>
        ))
      }
    </section>
  </div>

  <dialog class="slide-preview-dialog" aria-label="Перегляд слайдів">
    <div class="slide-preview-shell">
      <header class="slide-preview-header">
        <div>
          <p class="slide-preview-count">
            Слайд <span data-slide-current>1</span> / <span data-slide-total
              >1</span
            >
          </p>
          <h2 data-slide-title></h2>
        </div>
        <div class="slide-preview-actions">
          <button
            class="slide-preview-icon-button"
            type="button"
            data-preview-download
            aria-label="Завантажити PowerPoint"
            hidden
          >
            <svg
              class="slide-preview-button-icon"
              aria-hidden="true"
              viewBox="0 0 24 24"
            >
              <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
              <path d="M7 10l5 5 5-5"></path>
              <path d="M12 15V3"></path>
            </svg>
          </button>
          <button
            class="slide-preview-icon-button"
            type="button"
            data-preview-close
            aria-label="Закрити перегляд"
          >
            <svg
              class="slide-preview-button-icon"
              aria-hidden="true"
              viewBox="0 0 24 24"
            >
              <path d="M18 6 6 18"></path>
              <path d="m6 6 12 12"></path>
            </svg>
          </button>
        </div>
      </header>

      <div class="slide-preview-stage">
        <pre data-slide-preview-text></pre>
      </div>

      <footer class="slide-preview-footer">
        <button
          class="slide-preview-nav-button"
          type="button"
          data-preview-prev
          aria-label="Попередній слайд"
        >
          <svg
            class="slide-preview-button-icon"
            aria-hidden="true"
            viewBox="0 0 24 24"
          >
            <path d="m15 18-6-6 6-6"></path>
          </svg>
        </button>
        <button
          class="slide-preview-nav-button"
          type="button"
          data-preview-next
          aria-label="Наступний слайд"
        >
          <svg
            class="slide-preview-button-icon"
            aria-hidden="true"
            viewBox="0 0 24 24"
          >
            <path d="m9 18 6-6-6-6"></path>
          </svg>
        </button>
      </footer>
    </div>
  </dialog>

  <script>
    import pptxgen from "pptxgenjs";

    const copiedLabel = "Скопійовано";
    const defaultLabel = "Копіювати текст";
    const previewDialog = document.querySelector<HTMLDialogElement>(
      ".slide-preview-dialog",
    );
    const previewTitle =
      previewDialog?.querySelector<HTMLElement>("[data-slide-title]");
    const previewText = previewDialog?.querySelector<HTMLElement>(
      "[data-slide-preview-text]",
    );
    const previewStage =
      previewDialog?.querySelector<HTMLElement>(".slide-preview-stage");
    const previewCurrent = previewDialog?.querySelector<HTMLElement>(
      "[data-slide-current]",
    );
    const previewTotal =
      previewDialog?.querySelector<HTMLElement>("[data-slide-total]");
    const previewPrevious = previewDialog?.querySelector<HTMLButtonElement>(
      "[data-preview-prev]",
    );
    const previewNext = previewDialog?.querySelector<HTMLButtonElement>(
      "[data-preview-next]",
    );
    const previewClose = previewDialog?.querySelector<HTMLButtonElement>(
      "[data-preview-close]",
    );
    const previewDownload = previewDialog?.querySelector<HTMLButtonElement>(
      "[data-preview-download]",
    );

    type PreviewSlide = {
      text: string;
      title: string;
    };

    type PowerPointSlide = {
      text: string;
      title?: string;
    };

    type PreviewOptions = {
      downloadFilename?: string;
      downloadTitle?: string;
      powerpointSlides?: PowerPointSlide[];
    };

    let activeSlides: PreviewSlide[] = [];
    let activePowerPointSlides: PowerPointSlide[] = [];
    let activeDownloadFilename = "slides.pptx";
    let activeDownloadTitle = "slides";
    let activeSlideIndex = 0;
    let previewRequestedFullscreen = false;
    let swipeStartX = 0;
    let swipeStartY = 0;
    let swipeStartTime = 0;

    const writeToClipboard = async (text: string) => {
      if (navigator.clipboard?.writeText) {
        await navigator.clipboard.writeText(text);
        return;
      }

      const textarea = document.createElement("textarea");
      textarea.value = text;
      textarea.setAttribute("readonly", "");
      textarea.style.position = "fixed";
      textarea.style.top = "-1000px";
      document.body.append(textarea);
      textarea.select();
      document.execCommand("copy");
      textarea.remove();
    };

    const renderPreviewSlide = () => {
      if (
        !previewText ||
        !previewCurrent ||
        !previewTotal ||
        !previewPrevious ||
        !previewNext
      )
        return;

      const activeSlide = activeSlides[activeSlideIndex];

      previewText.textContent = activeSlide?.text ?? "";
      if (previewTitle) previewTitle.textContent = activeSlide?.title ?? "";
      previewCurrent.textContent = String(activeSlideIndex + 1);
      previewTotal.textContent = String(activeSlides.length);
      previewPrevious.disabled = activeSlideIndex === 0;
      previewNext.disabled = activeSlideIndex === activeSlides.length - 1;
      if (previewDownload) previewDownload.hidden = !activePowerPointSlides.length;
    };

    const showPreviewSlide = (direction: number) => {
      const nextIndex = activeSlideIndex + direction;

      if (nextIndex < 0 || nextIndex >= activeSlides.length) return;

      activeSlideIndex = nextIndex;
      renderPreviewSlide();
    };

    const getSongSlides = (songBlock: Element | null) =>
      Array.from(songBlock?.querySelectorAll(".slide-card pre") ?? [])
        .map((slide) => slide.textContent?.trim() ?? "")
        .filter(Boolean);

    const createPreviewSlides = (slides: string[], title: string) =>
      slides.map((slide) => ({ text: slide, title }));

    const getSongPreviewTitle = (songBlock: Element | null) => {
      const number =
        songBlock instanceof HTMLElement ? songBlock.dataset.songNumber : "";
      const title = songBlock?.querySelector("h2")?.textContent?.trim() ?? "";

      return number ? `${number}. ${title.replace(/^\d+\.\s*/, "")}` : title;
    };

    const openSlides = (slides: PreviewSlide[], options: PreviewOptions = {}) => {
      if (!previewDialog || !slides.length) return;

      activeSlides = slides;
      activePowerPointSlides = options.powerpointSlides ?? [];
      activeDownloadFilename = options.downloadFilename ?? "slides.pptx";
      activeDownloadTitle = options.downloadTitle ?? "slides";
      activeSlideIndex = 0;

      renderPreviewSlide();
      openPreview();
    };

    const normalizeSongId = (value: string) => {
      const trimmed = value.trim();

      if (!/^\d+$/.test(trimmed)) return "";

      return trimmed.padStart(3, "0");
    };

    const getGroupIdsFromUrl = () => {
      const params = new URLSearchParams(window.location.search);
      const queryGroup = params.get("group") ?? "";
      const hashGroup = decodeURIComponent(
        window.location.hash.replace(/^#/, ""),
      );
      const hashMatch = hashGroup.match(/^group=([\d,\s]+)$/);
      const source = queryGroup || hashMatch?.[1] || "";

      return source
        .split(",")
        .map(normalizeSongId)
        .filter(Boolean);
    };

    const openGroupFromUrl = () => {
      const ids = getGroupIdsFromUrl();

      if (!ids.length) return;

      const songBlocks = ids
        .map((id) =>
          document.querySelector<HTMLElement>(`.song-slides[data-song-id="${id}"]`),
        )
        .filter(Boolean);
      const slides: PreviewSlide[] = [];
      const powerpointSlides: PowerPointSlide[] = [];

      songBlocks.forEach((songBlock, index) => {
        const songTitle = getSongPreviewTitle(songBlock);
        const songSlides = getSongSlides(songBlock);

        slides.push(...createPreviewSlides(songSlides, songTitle));
        powerpointSlides.push(
          ...songSlides.map((slide, slideIndex) => ({
            text: slide,
            title: slideIndex === 0 ? songTitle : "",
          })),
        );

        if (index !== songBlocks.length - 1) {
          slides.push({ text: "", title: "" });
          powerpointSlides.push({ text: "", title: "" });
        }
      });

      if (!slides.length) return;

      openSlides(slides, {
        downloadFilename: `slides-${ids.join("-")}.pptx`,
        downloadTitle: `Слайди ${ids.join(", ")}`,
        powerpointSlides,
      });
    };

    const openPreview = async () => {
      if (!previewDialog) return;

      previewDialog.showModal();
      previewNext?.focus();

      try {
        await previewDialog.requestFullscreen();
        previewRequestedFullscreen = true;
      } catch {
        previewRequestedFullscreen = false;
      }
    };

    const closePreview = async () => {
      previewDialog?.close();

      if (previewRequestedFullscreen && document.fullscreenElement) {
        await document.exitFullscreen();
      }

      previewRequestedFullscreen = false;
    };

    const escapeXml = (value: string) =>
      value
        .replace(/&/g, "&amp;")
        .replace(/</g, "&lt;")
        .replace(/>/g, "&gt;")
        .replace(/"/g, "&quot;");

    const crcTable = Array.from({ length: 256 }, (_, index) => {
      let value = index;

      for (let bit = 0; bit < 8; bit += 1) {
        value = value & 1 ? 0xedb88320 ^ (value >>> 1) : value >>> 1;
      }

      return value >>> 0;
    });

    const getCrc32 = (bytes: Uint8Array) => {
      let crc = 0xffffffff;

      for (const byte of bytes) {
        crc = crcTable[(crc ^ byte) & 0xff] ^ (crc >>> 8);
      }

      return (crc ^ 0xffffffff) >>> 0;
    };

    const writeUint16 = (target: Uint8Array, offset: number, value: number) => {
      target[offset] = value & 0xff;
      target[offset + 1] = (value >>> 8) & 0xff;
    };

    const writeUint32 = (target: Uint8Array, offset: number, value: number) => {
      target[offset] = value & 0xff;
      target[offset + 1] = (value >>> 8) & 0xff;
      target[offset + 2] = (value >>> 16) & 0xff;
      target[offset + 3] = (value >>> 24) & 0xff;
    };

    const createZipBlob = (
      files: Array<{ name: string; content: string | Uint8Array }>,
    ) => {
      const encoder = new TextEncoder();
      const records = files.map((file) => {
        const nameBytes = encoder.encode(file.name);
        const contentBytes =
          typeof file.content === "string"
            ? encoder.encode(file.content)
            : file.content;

        return {
          ...file,
          nameBytes,
          contentBytes,
          crc: getCrc32(contentBytes),
          offset: 0,
        };
      });

      const localSize = records.reduce(
        (sum, record) => sum + 30 + record.nameBytes.length + record.contentBytes.length,
        0,
      );
      const centralSize = records.reduce(
        (sum, record) => sum + 46 + record.nameBytes.length,
        0,
      );
      const output = new Uint8Array(localSize + centralSize + 22);
      let offset = 0;

      records.forEach((record) => {
        record.offset = offset;
        writeUint32(output, offset, 0x04034b50);
        writeUint16(output, offset + 4, 20);
        writeUint16(output, offset + 6, 0);
        writeUint16(output, offset + 8, 0);
        writeUint16(output, offset + 10, 0);
        writeUint16(output, offset + 12, 0);
        writeUint32(output, offset + 14, record.crc);
        writeUint32(output, offset + 18, record.contentBytes.length);
        writeUint32(output, offset + 22, record.contentBytes.length);
        writeUint16(output, offset + 26, record.nameBytes.length);
        writeUint16(output, offset + 28, 0);
        output.set(record.nameBytes, offset + 30);
        output.set(record.contentBytes, offset + 30 + record.nameBytes.length);
        offset += 30 + record.nameBytes.length + record.contentBytes.length;
      });

      const centralOffset = offset;

      records.forEach((record) => {
        writeUint32(output, offset, 0x02014b50);
        writeUint16(output, offset + 4, 20);
        writeUint16(output, offset + 6, 20);
        writeUint16(output, offset + 8, 0);
        writeUint16(output, offset + 10, 0);
        writeUint16(output, offset + 12, 0);
        writeUint16(output, offset + 14, 0);
        writeUint32(output, offset + 16, record.crc);
        writeUint32(output, offset + 20, record.contentBytes.length);
        writeUint32(output, offset + 24, record.contentBytes.length);
        writeUint16(output, offset + 28, record.nameBytes.length);
        writeUint16(output, offset + 30, 0);
        writeUint16(output, offset + 32, 0);
        writeUint16(output, offset + 34, 0);
        writeUint16(output, offset + 36, 0);
        writeUint32(output, offset + 38, 0);
        writeUint32(output, offset + 42, record.offset);
        output.set(record.nameBytes, offset + 46);
        offset += 46 + record.nameBytes.length;
      });

      writeUint32(output, offset, 0x06054b50);
      writeUint16(output, offset + 4, 0);
      writeUint16(output, offset + 6, 0);
      writeUint16(output, offset + 8, records.length);
      writeUint16(output, offset + 10, records.length);
      writeUint32(output, offset + 12, centralSize);
      writeUint32(output, offset + 16, centralOffset);
      writeUint16(output, offset + 20, 0);

      return new Blob([output], {
        type: "application/vnd.openxmlformats-officedocument.presentationml.presentation",
      });
    };

    const createSlideXml = ({ text, title = "" }: PowerPointSlide) => {
      const slideTextTop = title ? 1371600 : 1143000;
      const slideTextHeight = title ? 4572000 : 4800600;
      const titleShape = title
        ? `<p:sp>
        <p:nvSpPr><p:cNvPr id="3" name="Song Title"/><p:cNvSpPr txBox="1"/><p:nvPr/></p:nvSpPr>
        <p:spPr><a:xfrm><a:off x="914400" y="548640"/><a:ext cx="10363200" cy="731520"/></a:xfrm><a:prstGeom prst="rect"><a:avLst/></a:prstGeom><a:noFill/></p:spPr>
        <p:txBody><a:bodyPr wrap="square" anchor="ctr" lIns="0" tIns="0" rIns="0" bIns="0"/><a:lstStyle/><a:p><a:pPr algn="ctr"/><a:r><a:rPr lang="uk-UA" sz="2600" b="1"><a:solidFill><a:srgbClr val="FFFDF9"/></a:solidFill><a:latin typeface="Arial"/><a:cs typeface="Arial"/></a:rPr><a:t>${escapeXml(title)}</a:t></a:r></a:p></p:txBody>
      </p:sp>`
        : "";
      const paragraphs = text
        .split(/\r?\n/)
        .map((line) => line.trim())
        .filter(Boolean)
        .map(
          (line) =>
            `<a:p><a:pPr algn="ctr"/><a:r><a:rPr lang="uk-UA" sz="4200" b="1"><a:solidFill><a:srgbClr val="FFFDF9"/></a:solidFill><a:latin typeface="Arial"/><a:cs typeface="Arial"/></a:rPr><a:t>${escapeXml(line)}</a:t></a:r></a:p>`,
        )
        .join("") || `<a:p><a:pPr algn="ctr"/></a:p>`;

      return `<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<p:sld xmlns:a="http://schemas.openxmlformats.org/drawingml/2006/main" xmlns:p="http://schemas.openxmlformats.org/presentationml/2006/main" xmlns:r="http://schemas.openxmlformats.org/officeDocument/2006/relationships">
  <p:cSld>
    <p:bg><p:bgPr><a:solidFill><a:srgbClr val="090A0D"/></a:solidFill><a:effectLst/></p:bgPr></p:bg>
    <p:spTree>
      <p:nvGrpSpPr><p:cNvPr id="1" name=""/><p:cNvGrpSpPr/><p:nvPr/></p:nvGrpSpPr>
      <p:grpSpPr><a:xfrm><a:off x="0" y="0"/><a:ext cx="0" cy="0"/><a:chOff x="0" y="0"/><a:chExt cx="0" cy="0"/></a:xfrm></p:grpSpPr>
      ${titleShape}
      <p:sp>
        <p:nvSpPr><p:cNvPr id="2" name="Slide Text"/><p:cNvSpPr txBox="1"/><p:nvPr/></p:nvSpPr>
        <p:spPr><a:xfrm><a:off x="914400" y="${slideTextTop}"/><a:ext cx="10363200" cy="${slideTextHeight}"/></a:xfrm><a:prstGeom prst="rect"><a:avLst/></a:prstGeom><a:noFill/></p:spPr>
        <p:txBody><a:bodyPr wrap="square" anchor="ctr" lIns="0" tIns="0" rIns="0" bIns="0"/><a:lstStyle/>${paragraphs}</p:txBody>
      </p:sp>
    </p:spTree>
  </p:cSld>
  <p:clrMapOvr><a:masterClrMapping/></p:clrMapOvr>
</p:sld>`;
    };

    const createPowerPointBlob = (slides: PowerPointSlide[]) => {
      const slideOverrides = slides
        .map(
          (_, index) =>
            `<Override PartName="/ppt/slides/slide${index + 1}.xml" ContentType="application/vnd.openxmlformats-officedocument.presentationml.slide+xml"/>`,
        )
        .join("");
      const slideIds = slides
        .map((_, index) => `<p:sldId id="${256 + index}" r:id="rId${index + 1}"/>`)
        .join("");
      const slideRelationships = slides
        .map(
          (_, index) =>
            `<Relationship Id="rId${index + 1}" Type="http://schemas.openxmlformats.org/officeDocument/2006/relationships/slide" Target="slides/slide${index + 1}.xml"/>`,
        )
        .join("");
      const files: Array<{ name: string; content: string }> = [
        {
          name: "[Content_Types].xml",
          content: `<?xml version="1.0" encoding="UTF-8" standalone="yes"?><Types xmlns="http://schemas.openxmlformats.org/package/2006/content-types"><Default Extension="rels" ContentType="application/vnd.openxmlformats-package.relationships+xml"/><Default Extension="xml" ContentType="application/xml"/><Override PartName="/ppt/presentation.xml" ContentType="application/vnd.openxmlformats-officedocument.presentationml.presentation.main+xml"/><Override PartName="/ppt/slideMasters/slideMaster1.xml" ContentType="application/vnd.openxmlformats-officedocument.presentationml.slideMaster+xml"/><Override PartName="/ppt/slideLayouts/slideLayout1.xml" ContentType="application/vnd.openxmlformats-officedocument.presentationml.slideLayout+xml"/><Override PartName="/ppt/theme/theme1.xml" ContentType="application/vnd.openxmlformats-officedocument.theme+xml"/><Override PartName="/docProps/core.xml" ContentType="application/vnd.openxmlformats-package.core-properties+xml"/><Override PartName="/docProps/app.xml" ContentType="application/vnd.openxmlformats-officedocument.extended-properties+xml"/>${slideOverrides}</Types>`,
        },
        {
          name: "_rels/.rels",
          content: `<?xml version="1.0" encoding="UTF-8" standalone="yes"?><Relationships xmlns="http://schemas.openxmlformats.org/package/2006/relationships"><Relationship Id="rId1" Type="http://schemas.openxmlformats.org/officeDocument/2006/relationships/officeDocument" Target="ppt/presentation.xml"/><Relationship Id="rId2" Type="http://schemas.openxmlformats.org/package/2006/relationships/metadata/core-properties" Target="docProps/core.xml"/><Relationship Id="rId3" Type="http://schemas.openxmlformats.org/officeDocument/2006/relationships/extended-properties" Target="docProps/app.xml"/></Relationships>`,
        },
        {
          name: "docProps/core.xml",
