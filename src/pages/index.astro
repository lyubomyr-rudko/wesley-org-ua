---
import { getCollection } from "astro:content";
import type { CollectionEntry } from "astro:content";
import "../styles/github-blog.css";

const posts = await getCollection("blog");
type BlogPostEntry = CollectionEntry<"blog">;
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Blog</title>
  </head>
  <body>
    <main class="home-page">
      <section class="hero">
        <p class="hero-eyebrow">Astro Blog</p>
        <h1 class="hero-title">My Blog</h1>
        <p class="hero-description">
          Notes, tutorials, and experiments while learning Astro.
        </p>
      </section>

      <section class="archive-card">
        <div class="archive-header">
          <h2>Post Archive</h2>
          <p>
            There are currently <span class="count">{posts.length}</span> posts
          </p>
        </div>

        <ul class="post-list">
          {
            posts.map((post: BlogPostEntry) => (
              <li class="post-item">
                <a
                  class="post-link"
                  href={`${import.meta.env.BASE_URL}posts/${post.id}/`}
                >
                  <span class="post-title">{post.data.title}</span>
                  {post.data.pubDate && (
                    <span class="post-date">{post.data.pubDate}</span>
                  )}
                </a>

                {post.data.description && (
                  <p class="post-description">{post.data.description}</p>
                )}
              </li>
            ))
          }
        </ul>
      </section>
    </main>
  </body>
</html>

<style>
  :global(:root) {
    --bgColor-default: #ffffff;
    --bgColor-muted: #f6f8fa;
    --fgColor-default: #1f2328;
    --fgColor-muted: #59636e;
    --borderColor-default: #d0d7de;
    --borderColor-muted: #d8dee4;
    --accent-fg: #0969da;
    --shadow-small: 0 1px 3px rgba(31, 35, 40, 0.08);
  }

  :global(body) {
    margin: 0;
    background: var(--bgColor-muted);
    color: var(--fgColor-default);
    font-family:
      -apple-system, BlinkMacSystemFont, "Segoe UI", Helvetica, Arial,
      sans-serif, "Apple Color Emoji", "Segoe UI Emoji";
  }

  .home-page {
    width: min(100%, 980px);
    margin: 0 auto;
    padding: 2rem 1rem 3rem;
  }

  .hero {
    margin-bottom: 1.5rem;
    padding: 2rem;
    background: var(--bgColor-default);
    border: 1px solid var(--borderColor-default);
    border-radius: 12px;
    box-shadow: var(--shadow-small);
  }

  .hero-eyebrow {
    margin: 0 0 0.75rem;
    color: var(--fgColor-muted);
    font-size: 0.875rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .hero-title {
    margin: 0;
    font-size: clamp(2rem, 5vw, 2.75rem);
    line-height: 1.15;
  }

  .hero-description {
    margin: 1rem 0 0;
    font-size: 1.05rem;
    color: var(--fgColor-muted);
    max-width: 720px;
  }

  .archive-card {
    background: var(--bgColor-default);
    border: 1px solid var(--borderColor-default);
    border-radius: 12px;
    box-shadow: var(--shadow-small);
    overflow: hidden;
  }

  .archive-header {
    padding: 1.5rem 2rem;
    border-bottom: 1px solid var(--borderColor-muted);
  }

  .archive-header h2 {
    margin: 0 0 0.5rem;
    font-size: 1.4rem;
  }

  .archive-header p {
    margin: 0;
    color: var(--fgColor-muted);
  }

  .count {
    color: var(--fgColor-default);
    font-weight: 600;
  }

  .post-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .post-item {
    padding: 1.25rem 2rem;
    border-top: 1px solid var(--borderColor-muted);
  }

  .post-item:first-child {
    border-top: 0;
  }

  .post-link {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
    color: inherit;
    text-decoration: none;
  }

  .post-link:hover .post-title {
    color: var(--accent-fg);
    text-decoration: underline;
  }

  .post-title {
    font-size: 1.05rem;
    font-weight: 600;
  }

  .post-date {
    white-space: nowrap;
    color: var(--fgColor-muted);
    font-size: 0.95rem;
  }

  .post-description {
    margin: 0.65rem 0 0;
    color: var(--fgColor-muted);
    line-height: 1.6;
  }

  @media (max-width: 720px) {
    .home-page {
      padding: 1rem 0.75rem 2rem;
    }

    .hero,
    .archive-header,
    .post-item {
      padding-left: 1rem;
      padding-right: 1rem;
    }

    .post-link {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.35rem;
    }
  }
</style>
