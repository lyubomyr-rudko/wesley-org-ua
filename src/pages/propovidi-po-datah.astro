---
import BaseLayout from "../layouts/BaseLayout.astro";
import { sermonSections, totalSermons } from "../data/sermons.js";

const baseUrl = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const withBase = (path) => `${baseUrl}${path.replace(/^\/+/, "")}`;
---

<BaseLayout
  title="Проповіді у Хронологічному порядку"
  description="Хронологічний каталог проповідей Джона Веслі з номерацією та датами Smith's і Outler's."
>
  <div class="resource-shell">
    <section class="resource-hero">
      <div class="resource-kicker">
        Хронологічний каталог
        <div class="social-icon-links" aria-label="Соціальні мережі">
          <a
            class="social-icon-link"
            href="https://t.me/wesley_ua"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Telegram канал"
          >
            <svg
              aria-hidden="true"
              viewBox="0 0 24 24"
              fill="currentColor"
              xmlns="http://www.w3.org/2000/svg"
            >
              <path
                d="M21.94 4.16a1.6 1.6 0 0 0-1.67-.26L3.4 10.43c-.65.25-1.07.72-1.09 1.24-.03.52.34.98 1 1.26l4.26 1.75 1.67 5.32c.18.58.58.95 1.08 1 .49.05.96-.23 1.28-.77l2.2-3.62 4.12 3.04c.48.36 1 .48 1.45.34.46-.14.78-.52.93-1.1l2.97-13.36c.13-.62-.12-1.12-.65-1.37Zm-4.41 3.32-7.84 7.1-.31 3.16-1.08-3.43 9.23-6.83Z"
              ></path>
            </svg>
          </a>
          <a
            class="social-icon-link"
            href="https://www.facebook.com/groups/1463091414059740"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Facebook група"
          >
            <svg
              aria-hidden="true"
              viewBox="0 0 24 24"
              fill="currentColor"
              xmlns="http://www.w3.org/2000/svg"
            >
              <path
                d="M22 12.07C22 6.5 17.52 2 12 2S2 6.5 2 12.07c0 5.02 3.66 9.18 8.44 9.93v-7.03H7.9v-2.9h2.54V9.41c0-2.5 1.5-3.88 3.78-3.88 1.1 0 2.25.2 2.25.2v2.48h-1.27c-1.25 0-1.64.78-1.64 1.58v1.9h2.8l-.45 2.9h-2.35V22c4.78-.75 8.44-4.91 8.44-9.93z"
              ></path>
            </svg>
          </a>
        </div>
      </div>
      <h1 class="resource-title">Проповіді у Хронологічному порядку</h1>
      <p class="resource-summary">
        Зібрання проповідей Джона Веслі, впорядковане за роками. Для кожної
        позиції показано номер проповіді, назву та дату.
      </p>
      <div class="home-actions">
        <a class="button-secondary" href={withBase("/propovidi/")}>
          Проповіді у Нумераційному порядку
        </a>
      </div>
    </section>

    <section class="resource-panel">
      <div class="resource-panel-header">
        <p class="archive-eyebrow">Повний перелік</p>
        <h2>Проповіді Джона Веслі за роками</h2>
        <p class="archive-summary">
          У хронологічному списку зараз:
          <span class="count"> {totalSermons}</span> проповідей
        </p>
      </div>

      {
        sermonSections.map((section) => (
          <section class="sermon-era">
            <div class="sermon-era-header">
              <h3 class="sermon-era-title">{section.decade}</h3>
              <p class="sermon-era-count">
                {section.sermons.length} проповідей
              </p>
            </div>

            <ol class="sermon-list">
              {section.sermons.map((sermon) => (
                <li class="sermon-item">
                  <div class="sermon-meta">
                    <span class="sermon-year">Дата: {sermon.smithDate}</span>
                    {sermon.outlerDate &&
                      sermon.outlerDate !== sermon.smithDate && (
                        <span class="sermon-original">
                          Альтернативна дата: {sermon.outlerDate}
                        </span>
                      )}
                  </div>
                  <h4 class="sermon-title">
                    <span class="sermon-number">
                      Проповідь № {sermon.number}
                    </span>
                    <a
                      class="sermon-link"
                      href={withBase(`/${sermon.contentPath}/`)}
                    >
                      {sermon.title}
                    </a>
                  </h4>
                </li>
              ))}
            </ol>
          </section>
        ))
      }
    </section>
  </div>
</BaseLayout>
