---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import {
  bibleBooks,
  bibleChapters,
  getAdjacentBibleChapters,
} from "../../../data/bible.js";

export const getStaticPaths = () =>
  bibleChapters.map((chapter) => ({
    params: {
      book: chapter.slug,
      chapter: String(chapter.chapter),
    },
    props: {
      chapter,
    },
  }));

const { chapter } = Astro.props;
const { previousChapter, nextChapter } = getAdjacentBibleChapters(chapter);
const currentBook = bibleBooks.find((book) => book.slug === chapter.slug);
const baseUrl = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const withBase = (path) => `${baseUrl}${path.replace(/^\/+/, "")}`;
---

<BaseLayout
  title={`${chapter.title} ${chapter.chapter} | Біблія`}
  description={`Читайте ${chapter.title}, розділ ${chapter.chapter}, українською.`}
>
  <article
    class="blog-post-card bible-reader"
    data-bible-reader
    data-book-title={chapter.title}
    data-citation-title={chapter.citationTitle ?? chapter.title}
    data-chapter-number={chapter.chapter}
  >
    <header class="post-header bible-reader-header">
      <p class="post-eyebrow">Українська Біблія Івана Огієнка</p>
      <h1>{chapter.title} {chapter.chapter}</h1>

      <form class="bible-picker bible-reader-picker" data-bible-picker>
        <label class="bible-picker-field">
          <span>Книга</span>
          <select name="book">
            {
              bibleBooks.map((book) => (
                <option
                  value={book.slug}
                  data-chapters={book.chapters.join(",")}
                  selected={book.slug === chapter.slug}
                >
                  {book.title}
                </option>
              ))
            }
          </select>
        </label>

        <label class="bible-picker-field">
          <span>Розділ</span>
          <select name="chapter" data-current-chapter={chapter.chapter}></select>
        </label>

        <button class="button-secondary bible-picker-button" type="submit">
          Перейти
        </button>
      </form>
    </header>

    <div class="bible-chapter-text" data-bible-chapter-text>
      {
        chapter.verses.map((verse) => (
          <p
            class="bible-verse"
            id={verse.number ? `v${verse.number}` : undefined}
            data-verse-number={verse.number}
          >
            {verse.number && <sup>{verse.number}</sup>}
            <span>{verse.text}</span>
          </p>
        ))
      }
    </div>

    <nav class="sermon-pagination bible-pagination" aria-label="Навігація розділами">
      {
        previousChapter ? (
          <a class="sermon-pagination-link" href={withBase(previousChapter.path)}>
            <span class="sermon-pagination-label">Попередній розділ</span>
            <span class="sermon-pagination-title">
              {previousChapter.title} {previousChapter.chapter}
            </span>
          </a>
        ) : (
          <span></span>
        )
      }

      {
        nextChapter ? (
          <a class="sermon-pagination-link is-next" href={withBase(nextChapter.path)}>
            <span class="sermon-pagination-label">Наступний розділ</span>
            <span class="sermon-pagination-title">
              {nextChapter.title} {nextChapter.chapter}
            </span>
          </a>
        ) : (
          <span></span>
        )
      }
    </nav>

    {
      currentBook && (
        <section class="bible-chapter-list" aria-label={`Інші розділи книги ${currentBook.title}`}>
          <h2>Розділи книги {currentBook.title}</h2>
          <ol>
            {currentBook.chapters.map((bookChapter) => (
              <li>
                <a
                  class={bookChapter === chapter.chapter ? "is-active" : undefined}
                  href={withBase(`/bible/${currentBook.slug}/${bookChapter}/`)}
                >
                  {bookChapter}
                </a>
              </li>
            ))}
          </ol>
        </section>
      )
    }
  </article>

  <script define:vars={{ baseUrl }}>
    const form = document.querySelector("[data-bible-picker]");
    const bookSelect = form?.elements.book;
    const chapterSelect = form?.elements.chapter;
    const bibleReader = document.querySelector("[data-bible-reader]");
    const bibleHeading = document.querySelector(".bible-reader-header h1");
    const bibleText = document.querySelector("[data-bible-chapter-text]");
    const superscriptDigits = {
      0: "⁰",
      1: "¹",
      2: "²",
      3: "³",
      4: "⁴",
      5: "⁵",
      6: "⁶",
      7: "⁷",
      8: "⁸",
      9: "⁹",
    };

    const renderChapters = () => {
      const selectedBook = bookSelect.selectedOptions[0];
      const chapters = selectedBook.dataset.chapters.split(",");
      const currentChapter = chapterSelect.dataset.currentChapter;

      chapterSelect.replaceChildren(
        ...chapters.map((chapter) => {
          const option = document.createElement("option");
          option.value = chapter;
          option.textContent = chapter;
          option.selected = chapter === currentChapter;
          return option;
        }),
      );
    };

    form?.addEventListener("submit", (event) => {
      event.preventDefault();
      window.location.href = `${baseUrl}bible/${bookSelect.value}/${chapterSelect.value}/`;
    });

    bookSelect?.addEventListener("change", () => {
      chapterSelect.dataset.currentChapter = "1";
      renderChapters();
    });
    renderChapters();

    const toSuperscript = (value) =>
      String(value).replace(/\d/g, (digit) => superscriptDigits[digit]);

    const getSelectedVerses = (selection) => {
      const verses = Array.from(bibleText.querySelectorAll("[data-verse-number]"));

      return verses.filter((verse) => {
        for (let index = 0; index < selection.rangeCount; index += 1) {
          if (selection.getRangeAt(index).intersectsNode(verse)) {
            return true;
          }
        }

        return false;
      });
    };

    const getReference = (verses) => {
      const verseNumbers = verses
        .map((verse) => Number(verse.dataset.verseNumber))
        .filter(Boolean);
      const firstVerse = verseNumbers[0];
      const lastVerse = verseNumbers.at(-1);
      const verseRange = firstVerse === lastVerse ? firstVerse : `${firstVerse}-${lastVerse}`;

      const headingBookTitle =
        bibleHeading?.textContent?.replace(/\s+\d+\s*$/, "").trim() ?? "";
      const selectedBookTitle =
        bookSelect?.selectedOptions[0]?.textContent?.trim() ?? "";
      const citationTitle =
        bibleReader?.dataset.citationTitle ||
        bibleReader?.dataset.bookTitle ||
        headingBookTitle ||
        selectedBookTitle;
      const chapterNumber = bibleReader?.dataset.chapterNumber ?? "";

      return `${citationTitle} ${chapterNumber}:${verseRange}`;
    };

    document.addEventListener("copy", (event) => {
      const selection = window.getSelection();

      if (!selection || selection.isCollapsed || !bibleText) {
        return;
      }

      const selectedVerses = getSelectedVerses(selection);

      if (selectedVerses.length === 0) {
        return;
      }

      const copiedText = selectedVerses
        .map((verse) => {
          const verseNumber = verse.dataset.verseNumber;
          const verseText = verse.querySelector("span")?.textContent?.trim() ?? "";

          return `${toSuperscript(verseNumber)} ${verseText}`;
        })
        .join("\n");

      event.preventDefault();
      if (!event.clipboardData) {
        return;
      }

      event.clipboardData.setData(
        "text/plain",
        `${copiedText}\n${getReference(selectedVerses)}`,
      );
    });
  </script>
</BaseLayout>
