---
import "../styles/github-blog.css";
const { title = "Джон Веслі українською", description = "" } = Astro.props;
const currentPath = Astro.url.pathname;
const isActivePath = (path) =>
  currentPath === path || currentPath === path.replace(/\/$/, "");
---

<!doctype html>
<html lang="uk">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body>
    <header class="site-header">
      <div class="container header-inner">
        <a href="/" class="brand">Центр Джона Веслі українською</a>
        <nav class="nav">
          <a href="/" class={currentPath === "/" ? "is-active" : undefined}>Головна</a>
          <a
            href="/propovidi/"
            class={isActivePath("/propovidi/") ? "is-active" : undefined}
          >
            Проповіді
          </a>
          <a
            href="/propovidi-po-datah/"
            class={isActivePath("/propovidi-po-datah/") ? "is-active" : undefined}
          >
            Проповіді у Хронологічному порядку
          </a>
        </nav>
      </div>
    </header>

    <main class="container page-content">
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container footer-inner">
        <div class="footer-copy">
          <p class="footer-title">Центр Джона Веслі українською</p>
          <p class="footer-text">
            Тексти, переклади та матеріали про проповідь, богослов'я і духовну
            спадщину Джона Веслі.
          </p>
        </div>
        <p class="footer-note">Жива віра, святість серця і служіння ближньому.</p>
      </div>
    </footer>
  </body>
</html>
